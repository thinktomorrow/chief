        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unicorn": "^65.0.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-fetch-mock": "^3.2.0",
        "laravel-vite-plugin": "^1.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.9.5",
        "prettier-plugin-blade": "^3.2.2",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "shelljs": "^0.10.0",
        "tailwindcss": "^4.3.2",
        "vite": "^6.4.3",
